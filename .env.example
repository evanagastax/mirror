# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Supabase — get these from: supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — get this from: sentry.io → your project → Settings → Client Keys (DSN)
# Leave blank to disable Sentry (safe for local dev without a Sentry project)
EXPO_PUBLIC_SENTRY_DSN=
