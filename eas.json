{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "applicationArchivePath": "android/app/build/outputs/apk/**/*.apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "applicationArchivePath": "android/app/build/outputs/apk/**/*.apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "applicationArchivePath": "android/app/build/outputs/bundle/**/*.aab"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
